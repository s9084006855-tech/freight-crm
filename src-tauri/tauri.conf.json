{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freight CRM",
  "version": "0.3.0",
  "identifier": "com.franciscopelaez.freight-crm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Freight CRM",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWRANHENghAJ4k1XgqWGLSnDWtDudCghIw6EKX1trjHmPfkwzyYCT2ni",
      "endpoints": [
        "https://github.com/s9084006855-tech/freight-crm/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/vision_ocr": "vision_ocr"
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    }
  }
}
